"""
Star Schema ETL para Alojamento Local
Cria um Data Warehouse com esquema em estrela a partir dos dados RNAL
Grão: ANO × CONCELHO × MODALIDADE
"""

import pandas as pd
import sys


def load_data():
    """Carrega o dataset original de estabelecimentos de alojamento local."""
    try:
        df = pd.read_csv(
            'Estabelecimentos_de_Alojamento_Local.csv',
            encoding='ISO-8859-1',
            on_bad_lines='skip'
        )
        print(f"Dataset carregado: {df.shape[0]} linhas")
        return df
    except FileNotFoundError:
        print("Erro: Ficheiro 'Estabelecimentos_de_Alojamento_Local.csv' não encontrado.")
        sys.exit(1)


def clean_data(df):
    """Limpa e prepara os dados para o ETL."""
    df['DataRegisto'] = pd.to_datetime(df['DataRegisto'], errors='coerce')
    
    required_columns = ['DataRegisto', 'Concelho', 'Distrito', 'NUTSII', 'Modalidade']
    df_clean = df.dropna(subset=required_columns)
    
    print(f"Após limpeza: {df_clean.shape[0]} linhas")
    return df_clean


def create_dim_tempo(df):
    """Cria a dimensão tempo (grão anual)."""
    df['ano'] = df['DataRegisto'].dt.year
    anos_unicos = sorted(df['ano'].unique())
    
    dim_tempo = pd.DataFrame({
        'id_tempo': range(1, len(anos_unicos) + 1),
        'ano': anos_unicos
    })
    
    return dim_tempo


def create_dim_regiao(df):
    """Cria a dimensão região (Concelho, Distrito, NUTS II)."""
    dim_regiao = df[['Concelho', 'Distrito', 'NUTSII']].drop_duplicates()
    dim_regiao = dim_regiao.reset_index(drop=True)
    dim_regiao['id_regiao'] = range(1, len(dim_regiao) + 1)
    # Renomear NUTSII para NUTS_II para melhor legibilidade
    dim_regiao = dim_regiao.rename(columns={'NUTSII': 'NUTS_II'})
    
    return dim_regiao


def create_dim_modalidade(df):
    """Cria a dimensão modalidade."""
    modalidades_unicas = df['Modalidade'].drop_duplicates().dropna()
    
    dim_modalidade = pd.DataFrame({
        'id_modalidade': range(1, len(modalidades_unicas) + 1),
        'modalidade': modalidades_unicas.values
    })
    
    return dim_modalidade


def create_fact_table(df, dim_tempo, dim_regiao, dim_modalidade):
    """Cria a tabela de factos com métricas agregadas."""
    # Mapear IDs das dimensões
    df = df.merge(dim_tempo, on='ano', how='left')
    
    # Para dim_regiao, usar os nomes originais das colunas
    dim_regiao_merge = dim_regiao.rename(columns={'NUTS_II': 'NUTSII'})
    df = df.merge(
        dim_regiao_merge,
        on=['Concelho', 'Distrito', 'NUTSII'],
        how='left'
    )
    df = df.merge(dim_modalidade, left_on='Modalidade', right_on='modalidade', how='left')
    
    # Agregar ao nível do grão definido
    fact_oferta = df.groupby(['id_tempo', 'id_regiao', 'id_modalidade']).agg({
        'NrRNAL': 'count',
        'NrUtentes': 'sum'
    }).reset_index()
    
    fact_oferta.columns = [
        'id_tempo', 'id_regiao', 'id_modalidade',
        'num_alojamentos', 'total_utentes'
    ]
    
    return fact_oferta


def export_tables(dim_tempo, dim_regiao, dim_modalidade, fact_oferta):
    """Exporta todas as tabelas para ficheiros CSV."""
    dim_tempo.to_csv('Dim_Tempo.csv', index=False)
    dim_regiao.to_csv('Dim_Regiao.csv', index=False)
    dim_modalidade.to_csv('Dim_Modalidade.csv', index=False)
    fact_oferta.to_csv('Fact_OfertaAL.csv', index=False)


def print_summary(dim_tempo, dim_regiao, dim_modalidade, fact_oferta):
    """Imprime um resumo do Data Warehouse criado."""
    print("\n" + "=" * 50)
    print("✅ DATA WAREHOUSE CRIADO!")
    print("=" * 50)
    print(f"📅 Dim_Tempo: {len(dim_tempo)} linhas "
          f"(anos: {dim_tempo['ano'].min()}-{dim_tempo['ano'].max()})")
    print(f"🗺️  Dim_Regiao: {len(dim_regiao)} linhas")
    print(f"🎯 Dim_Modalidade: {len(dim_modalidade)} linhas")
    print(f"⭐ Fact_OfertaAL: {len(fact_oferta)} linhas")
    print(f"📊 Grão: ANO × CONCELHO × MODALIDADE")
    print("\n🔗 Ficheiros exportados:")
    print("   - Dim_Tempo.csv")
    print("   - Dim_Regiao.csv")
    print("   - Dim_Modalidade.csv")
    print("   - Fact_OfertaAL.csv")


def main():
    """Função principal que executa o pipeline ETL."""
    # ETL Pipeline
    df_raw = load_data()
    df_clean = clean_data(df_raw)
    
    # Criar dimensões
    dim_tempo = create_dim_tempo(df_clean)
    dim_regiao = create_dim_regiao(df_clean)
    dim_modalidade = create_dim_modalidade(df_clean)
    
    # Criar tabela de factos
    fact_oferta = create_fact_table(df_clean, dim_tempo, dim_regiao, dim_modalidade)
    
    # Exportar
    export_tables(dim_tempo, dim_regiao, dim_modalidade, fact_oferta)
    
    # Resumo
    print_summary(dim_tempo, dim_regiao, dim_modalidade, fact_oferta)


if __name__ == "__main__":
    main()
